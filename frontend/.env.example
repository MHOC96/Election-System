# Local dev: Vite proxies /api → http://localhost:8000 (see vite.config.ts)
VITE_API_URL=/api

# Public site URL for canonical links, Open Graph, and sitemap (no trailing slash).
# Production example: https://elections.yourinstitution.edu
VITE_SITE_URL=

# Production (Vercel): set this in Vercel → Project → Environment Variables, then redeploy.
# Must be your Render backend URL including /api — NOT /api alone.
# Example:
# VITE_API_URL=https://your-service.onrender.com/api
