# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — Supabase transaction pooler (recommended)
# Paste from Supabase: Project Settings → Database → Connection string → Transaction pooler
# Port must be 6543. URL-encode special characters in the password (@ → %40, etc.)
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Or use individual vars (direct / session connection, port 5432) instead of DATABASE_URL:
# DB_NAME=postgres
# DB_USER=postgres.PROJECT_REF
# DB_PASSWORD=your_password
# DB_HOST=aws-0-REGION.pooler.supabase.com
# DB_PORT=5432

# CORS (comma-separated origins; include any Vite dev port, e.g. 5173 or 5174)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Redis — required when DEBUG=False (shared cache across Gunicorn/uWSGI workers).
# Used for dashboard stats, ongoing-election lookup, debounced MV refresh, and position lists.
# Local dev: omit to use in-process LocMem cache (single worker only).
# Example (Upstash / Redis Cloud): rediss://default:PASSWORD@HOST:6379/0
REDIS_URL=

# JWT (minutes)
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=1440

# Cloudinary — https://console.cloudinary.com/settings/api-keys
# Cloud name is NOT a label like "image"; it is the unique id shown on that page (e.g. dxy1abc23).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
